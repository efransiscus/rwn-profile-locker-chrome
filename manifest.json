{
  "manifest_version": 3,
  "name": "rwn Profile Lock",
  "version": "1.0.1",
  "description": "PIN-lock your Chrome profile. Re-locks on idle and restart.",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "tabs",
    "idle",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "rwn Profile Lock",
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "pages/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "incognito": "split"
}
